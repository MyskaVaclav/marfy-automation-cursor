# Marfy login used by the ingest30m job.
MARFY_EMAIL=your-marfy-email@example.com
MARFY_PASSWORD=your-marfy-password

# Google Sheets target.
SHEETS_ID=your-google-spreadsheet-id
SHEET_NAME=Sheet1

# Google service account authentication.
# Use either GOOGLE_APPLICATION_CREDENTIALS or GOOGLE_CREDENTIALS_BASE64.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# GOOGLE_CREDENTIALS_BASE64=base64-encoded-service-account-json

# Daily report delivery.
REPORT_TO_EMAIL=recipient@example.com
DRIVE_FOLDER_ID=your-google-drive-folder-id

# SMTP settings used by the dailyReport job.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASS=smtp-password

# Optional: set to false, 0, or no to keep rows after dailyReport.
CLEAR_SHEET=true
